<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="debug" monitorInterval="5">
    <!--ê³µي†µ ى†چى„± ى„¤ى • -->
    <Properties>
        <Property name="logFileName">moneyManager</Property>
        <Property name="consoleLayout">%highlight{[%-5level]}{FATAL=bg_red, ERROR=red, INFO=green, DEBUG=blue} %style{%d{yyyy-MM-dd HH:mm:ss}:%-3relative}{cyan}    %style{[%M]}{yellow} %logger{35} - %msg%n</Property>
        <Property name="fileLayout">%d [%t] %-5level %c(%M:%L) - %m%n</Property>
    </Properties>

    <!-- ë،œê·¸ ى¶œë ¥ ë°©ë²• ë°ڈ file ىƒ‌ى„± ى„¤ى • -->
    <Appenders>
        <Console name="console" target="SYSTEM_OUT">
            <PatternLayout pattern="${consoleLayout}" disableAnsi="false" />
            <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>

        <Console name="console-debug" target="SYSTEM_OUT">
            <PatternLayout pattern="${consoleLayout}" disableAnsi="false" />
            <Filters>
                <ThresholdFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </Console>

        <!--ConsoleAppender, RollingFileAppneder -->
        <RollingFile name="file"
                     fileName="logs/main/${logFileName}.log"
                     filePattern="logs/main/%d{yyyy-MM-dd} ${logFileName}.log">
            <PatternLayout pattern="${fileLayout}" />
            <LevelRangeFilter minLevel="DEBUG" maxLevel="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <MarkerFilter marker="SYSTEM_INFO" onMatch="DENY" onMismatch="ACCEPT"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy max="5" fileIndex="min" > <!-- ë،¤ë§پ يŒŒى‌¼ 5ê°œ ê¹Œى§€ ىƒ‌ى„± -->
                <Delete basePath="/logs" maxDepth="3">
                    <IfLastModified age="10d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <RollingFile name="system-info"
                     fileName="logs/info/system-info.log"
                     filePattern="logs/info/%d{yyyy-MM-dd} system-info.log">
            <PatternLayout pattern="${fileLayout}"/>
            <LevelRangeFilter minLevel="INFO" maxLevel="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <MarkerFilter marker="SYSTEM_INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20MB" />
            </Policies>
        </RollingFile>

        <!-- ى‚¬ىڑ©ى‍گ ى‍…ë ¥ WARN -->
        <RollingFile name="warn-client"
                     fileName="logs/warn/client-warn.log"
                    filePattern="logs/warn/%d{yyyy-MM-dd} client-warn.log">
            <PatternLayout pattern="${fileLayout}"/>
            <LevelRangeFilter minLevel="WARN" maxLevel="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
            <MarkerFilter marker="USER_WARN" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20MB" />
            </Policies>
        </RollingFile>

        <!-- ى‹œىٹ¤ي…œ ىکˆë°© WARN -->
        <RollingFile name="warn-system"
                            fileName="logs/warn/system-warn.log"
                            filePattern="logs/warn/%d{yyyy-MM-dd} client-warn.log">
            <PatternLayout pattern="${fileLayout}"/>
            <LevelRangeFilter minLevel="WARN" maxLevel="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
            <MarkerFilter marker="USER_WARN" onMatch="DENY" onMismatch="ACCEPT"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20MB" />
            </Policies>
        </RollingFile>

        <RollingFile name="error"
                     fileName="logs/error/system-error.log"
                     filePattern="logs/error/%d{yyyy-MM-dd} system-error.log">
            <PatternLayout pattern="${fileLayout}" />
            <!--LevelRangeFilterي•„ي„°ë¥¼ ى‚¬ىڑ©ي• ë•Œى—گ ë‹¨ى‌¼ levelى‌ک ي•„ي„°ë§Œ ي—ˆىڑ©ي•œë‹¤. -->
            <LevelRangeFilter minLevel="ERROR" maxLevel="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20 MB" />
            </Policies>
            <DefaultRolloverStrategy>
                <Delete basePath="/logs" maxDepth="3">
                    <IfLastModified age="10d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <!--TRACE > DEBUG > INFO > WARN > ERROR > FATAL -->
    <!--Logê°€ ى°چي‍گ ëŒ€ىƒپ ى„¤ى •.-->
    <Loggers>
        <!-- ىٹ¤ي”„ë§پ ي”„ë ˆى‍„ى›Œيپ¬ى—گى„œ ى°چëٹ”ê±´ levelى‌„ infoë،œ ى„¤ى • -->
        <logger name="com.moneymanager" level="debug" additivity="false" >
            <AppenderRef ref="main" />
        </logger>

        <logger name="com.moneymanager.controller" level="info" additivity="false" >
            <AppenderRef ref="console" />
        </logger>

        <logger name="com.moneymanager.service" level="info" additivity="false" >
            <AppenderRef ref="console" />
        </logger>

        <Logger name="com.moneymanager.utils.LoggerUtil" level="debug" additivity="false">
            <AppenderRef ref="console-debug"/>
            <AppenderRef ref="warn-client"/>
            <AppenderRef ref="system-info" />
            <AppenderRef ref="error" />
        </Logger>

        <Logger name="org.springframework.web" level="error" additivity="false">
            <AppenderRef ref="error" />
        </Logger>

        <!-- ROOT logger-->
        <Root level="info">
            <AppenderRef ref="file" />
            <AppenderRef ref="console" />

            <AppenderRef ref="warn-user"/>
            <AppenderRef ref="warn-system"/>
            <AppenderRef ref="error" />
            <AppenderRef ref="info" />
        </Root>

    </Loggers>
</Configuration>